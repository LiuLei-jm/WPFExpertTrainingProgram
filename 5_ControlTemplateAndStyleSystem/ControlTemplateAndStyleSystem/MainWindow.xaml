<Window x:Class="ControlTemplateAndStyleSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ControlTemplateAndStyleSystem"
        mc:Ignorable="d"
        Title="MainWindow" Height="350" Width="400">
    <Grid Margin="30">
        <StackPanel Margin="20">
            <StackPanel Margin="0 0 0 20" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" FontSize="14" Width="150" Text="普通开关（默认绿色）:"/>
                <local:CustomToggleSwitch />
            </StackPanel>
            <StackPanel Margin="0 0 0 20" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" FontSize="14" Width="150" Text="危险操作（改为红色）:"/>
                <local:CustomToggleSwitch CheckedBackground="Crimson"/>
            </StackPanel>
            <StackPanel Margin="0 0 0 20" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" FontSize="14" Width="150" Text="Wi-Fi 开关："/>
                <local:CustomToggleSwitch IsChecked="{Binding IsWifiEnabled}"/>
                <TextBlock VerticalAlignment="Center" FontSize="14" Margin="15 0 0 0" Text="{Binding IsWifiEnabled}"/>
            </StackPanel>
            <StackPanel Margin="0 0 0 20" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" FontSize="14" Width="150" Text="被禁用的开关："/>
                <local:CustomToggleSwitch IsChecked="True" IsEnabled="False"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>

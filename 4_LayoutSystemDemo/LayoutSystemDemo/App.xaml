<Application x:Class="LayoutSystemDemo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LayoutSystemDemo"
             xmlns:logging="clr-namespace:LayoutSystemDemo.Logging"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <DataTemplate x:Key="LogMessageDataTemplate" DataType="{x:Type logging:LogMessage}" >
            <TextBlock>
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Level}" Value="Debug">
                                <Setter Property="Foreground" Value="Gray"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                <Setter Property="Foreground" Value="DarkOrange"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                <Setter Property="Foreground" Value="Red"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <Run Text="{Binding Time, StringFormat='HH:mm:ss.fff'}"/>
                <Run Text=" "/>
                <Run Text="{Binding Level, StringFormat='[{0}]'}"/>
                <Run Text=" "/>
                <Run Text="{Binding Message}"/>
            </TextBlock>
        </DataTemplate>
    </Application.Resources>
</Application>

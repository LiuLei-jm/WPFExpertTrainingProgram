<Window x:Class="LayoutSystemDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LayoutSystemDemo"
        xmlns:ctrl="clr-namespace:LayoutSystemDemo.Controls"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="800">
    <Window.Resources>
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="260"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Margin="5" Style="{StaticResource HeaderTextStyle}" Text="UniformSpacingPanel"/>
        <StackPanel Margin="5 5 5 50" HorizontalAlignment="Left" Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center" Text="Total Items: "/>
            <TextBlock x:Name="UniformPanelItemsCount" Margin="5 0" VerticalAlignment="Center" Text="0"/>
            <Button Margin="5 0 0 0" Click="AddItemsUniformPanel_Click" Content="Add Item"/>
            <Button Margin="5 0 0 0" Click="ClearItemsFromUniformPanel_Click" Content="Clear Item"/>
        </StackPanel>
        <Border Grid.Row="1" Height="100" Margin="5" BorderBrush="Blue" BorderThickness="1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ctrl:UniformSpacingPanel x:Name="myUniformPanel" ItemSpacing="10"/>
            </ScrollViewer>
        </Border>

        <TextBlock Margin="5" Grid.Column="1" Style="{StaticResource HeaderTextStyle}" Text="SimpleVirtualizingPanel"/>
        <StackPanel Margin="5 5 5 50" Grid.Column="1" HorizontalAlignment="Left" Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center" Text="Total Items: "/>
            <TextBlock x:Name="VirtualPanelItemCount" Margin="5 0" VerticalAlignment="Center" Text="0"/>
            <Button Margin="5 0 0 0" Click="AddOneThousandItemsToVirtualPanel_Click" Content="Add 1000 Items"/>
            <Button Margin="5 0 0 0" Click="ClearItemsFromVirtualPanel_Click" Content="Clear Items"/>
        </StackPanel>
        <Border Grid.Row="1" Grid.Column="1" MaxHeight="100" Margin="5" BorderBrush="Green" BorderThickness="1">
            <ListBox x:Name="myVirtualizingItemsControl" VirtualizingPanel.IsVirtualizing="True">
                
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <ctrl:SimpleVirtualizingPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" BorderThickness="0 0 0 1">
                            <TextBlock Margin="5" VerticalAlignment="Center" Text="{Binding}"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
            <Button Margin="5" Click="LogInfo_Click" Content="Log Info"/>
            <Button Margin="5" Click="LogWarning_Click" Content="Log Warning"/>
            <Button Margin="5" Click="LogError_Click" Content="Log Error"/>
            <Button Margin="5" Click="LogDebug_Click" Content="Log Debug"/>
        </StackPanel>

        <Grid Grid.Row="3" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Margin="5" HorizontalAlignment="Center" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="Log Filter: "/>
                <ComboBox x:Name="LogLevelFilter" Width="150" VerticalAlignment="Center" SelectionChanged="LogLevelFilter_SelectionChanged">
                    <ComboBoxItem Content="Info"/>
                    <ComboBoxItem Content="Warning"/>
                    <ComboBoxItem Content="Error"/>
                    <ComboBoxItem Content="Debug"/>
                </ComboBox>
                <TextBlock Margin="10 0 0 0" VerticalAlignment="Center" Text="Search: "/>
                <TextBox x:Name="LogSearchText" Width="150" VerticalAlignment="Center" TextChanged="LogTextSearch_TextChanged"/>
                <Button Margin="10 0" Click="LogPauseScroll_Click" Content="Pause Scroll"/>
                <Button Margin="10 0" Click="LogResumeScroll_Click" Content="Resume Scroll"/>
            </StackPanel>

            <ctrl:LogPanel x:Name="myLogPanel" Grid.Row="1" MaxHeight="200" Margin="5"/>
        </Grid>
    </Grid>
</Window>

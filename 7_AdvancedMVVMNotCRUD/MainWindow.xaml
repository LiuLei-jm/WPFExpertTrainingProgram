<Window x:Class="AdvancedMVVMNotCRUD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdvancedMVVMNotCRUD"
        xmlns:vm="clr-namespace:AdvancedMVVMNotCRUD.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Window.DataContext>
        <vm:DownloadViewModel/>
    </Window.DataContext>
    <StackPanel Margin="50">
        <Button Width="150"
        Height="40"
        Command="{Binding DownloadCommand}"
        Content="开始下载"/>
        <Button Width="150"
        Height="40"
        Command="{Binding DownloadCommand.CancelCommand}"
        Background="LightCoral"
        Content="取消下载"/>
        <Button Width="150"
        Height="40"
        Command="{Binding ClearCommand}"
        Content="清空屏幕"/>
        <TextBlock Foreground="Blue" Text="拼命加载中" Visibility="{Binding DownloadCommand.IsExecuting, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <TextBlock FontSize="16" Text="{Binding ResultText}"/>
        <TextBlock FontSize="16" Text="{Binding ErrorMessage}" Foreground="Red"/>
    </StackPanel>
</Window>

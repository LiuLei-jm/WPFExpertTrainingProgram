<Window x:Class="InDepthAnalysisOfDP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InDepthAnalysisOfDP"
        xmlns:vm="clr-namespace:InDepthAnalysisOfDP.ViewModels"
        xmlns:cc="clr-namespace:InDepthAnalysisOfDP.CustomControls"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <cc:NumericUpDown
            Width="150"
            Height="35"
            Min="0"
            Max="100"
            Step="0.5"
            Precision="2"
            Value="{Binding Number,ValidatesOnDataErrors=True}"/>
    </Grid>
</Window>
